{
  "name": "copilot-quick-prompts",
  "displayName": "Copilot Quick Prompts",
  "description": "Quick prompt buttons for Copilot Chat — one-click insert of preset prompts",
  "version": "0.1.0",
  "publisher": "copilot-quick-prompts",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Copilot Quick Prompts",
      "properties": {
        "copilotQuickPrompts.statusBarPosition": {
          "type": "string",
          "enum": [
            "leftLeft",
            "leftRight",
            "rightLeft",
            "rightRight"
          ],
          "enumDescriptions": [
            "Left edge",
            "Left (default)",
            "Right",
            "Right edge"
          ],
          "default": "leftRight",
          "description": "Display position of status bar quick buttons"
        },
        "copilotQuickPrompts.prompts": {
          "type": "array",
          "default": [],
          "description": "Custom quick prompts list (JSON array). Each item: { id, icon, label, prompt, color, mode, displayMode, hidden?, builtIn? }",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "commands": [
      {
        "command": "copilotQuickPrompts.sendPrompt",
        "title": "Send quick prompt to Copilot Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-quick-prompts",
          "title": "Quick Prompts",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "copilot-quick-prompts": [
        {
          "type": "webview",
          "id": "copilotQuickPrompts.main",
          "name": "Quick Prompts"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "typescript": "^5.3.0"
  }
}
