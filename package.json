{
  "name": "copilot-kit",
  "displayName": "Copilot Kit",
  "description": "Quick prompt buttons for Copilot Chat — one-click insert of preset prompts",
  "version": "0.1.0",
  "publisher": "Copilot-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/liumin1128/copilot-kit"
  },
  "bugs": {
    "url": "https://github.com/liumin1128/copilot-kit/issues"
  },
  "homepage": "https://github.com/liumin1128/copilot-kit#readme",
  "keywords": [
    "copilot",
    "chat",
    "quick-prompt",
    "productivity",
    "shortcuts"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Copilot Kit",
      "properties": {
        "copilotKit.statusBarPosition": {
          "type": "string",
          "enum": [
            "leftLeft",
            "leftRight",
            "rightLeft",
            "rightRight"
          ],
          "enumDescriptions": [
            "Left edge",
            "Left (default)",
            "Right",
            "Right edge"
          ],
          "default": "leftRight",
          "description": "Display position of status bar quick buttons"
        },
        "copilotKit.prompts": {
          "type": "array",
          "default": [],
          "description": "Custom quick prompts list (JSON array). Each item: { id, icon, label, prompt, color, mode, displayMode, hidden?, builtIn? }",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "commands": [
      {
        "command": "copilotKit.sendPrompt",
        "title": "Send quick prompt to Copilot Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-kit",
          "title": "Quick Prompts",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "copilot-kit": [
        {
          "type": "webview",
          "id": "copilotKit.main",
          "name": "Quick Prompts"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "typescript": "^5.3.0"
  }
}
