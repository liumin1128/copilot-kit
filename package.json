{
  "name": "copilot-quick-prompts",
  "displayName": "Copilot Quick Prompts",
  "description": "为Copilot聊天添加快捷提示词按钮，一键插入预设提示词",
  "version": "0.1.0",
  "publisher": "copilot-quick-prompts",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Copilot Quick Prompts",
      "properties": {
        "copilotQuickPrompts.statusBarPosition": {
          "type": "string",
          "enum": [
            "leftLeft",
            "leftRight",
            "rightLeft",
            "rightRight"
          ],
          "enumDescriptions": [
            "左侧靠边",
            "左侧（默认）",
            "右侧",
            "右侧靠边"
          ],
          "default": "leftRight",
          "description": "状态栏快捷按钮的显示位置"
        }
      }
    },
    "commands": [
      {
        "command": "copilotQuickPrompts.sendPrompt",
        "title": "发送快捷提示词到Copilot聊天"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-quick-prompts",
          "title": "快捷提示",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "copilot-quick-prompts": [
        {
          "type": "webview",
          "id": "copilotQuickPrompts.main",
          "name": "快捷提示词"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "typescript": "^5.3.0"
  }
}
